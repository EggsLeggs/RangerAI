# source of truth for required validation: packages/shared/src/env.ts

# data sources
INATURALIST_API_KEY= # optional
GBIF_TOKEN= # required
IUCN_TOKEN= # required

# vision model + illustrated reports (gpt-4o and dall-e 3 both use this key)
OPENAI_API_KEY= # required

# guardrails
CIVIC_API_KEY= # required
# default used when unset
MCP_PORT=3001

# alert dispatch
# optional at load time: sms is stubbed without twilio credentials
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TO_NUMBER=

# dashboard/webhook dispatch
# default used when unset
WEBHOOK_URL=http://localhost:3000/api/alerts
